# Civic Twin Navigator - Frontend .gcloudignore
# Controls what is uploaded to Cloud Build when running:
#   gcloud run deploy --source .
# NOTE: This file takes precedence over .gitignore for gcloud commands.

# Dependencies (reinstalled during Docker build)
node_modules/

# Build output (rebuilt during Docker build)
dist/
build/

# Git
.git/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Tests
coverage/

# Local-only env files
.env.local
.env.development
.env.development.local
.env.test
.env.test.local

# IMPORTANT: .env and .env.production are intentionally NOT ignored here.
# Vite requires .env.production at Docker build time for VITE_* variable injection.
