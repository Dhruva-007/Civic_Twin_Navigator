# ─────────────────────────────────────────────
# Civic Twin Navigator - Root .gitignore
# ─────────────────────────────────────────────

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-link
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual Environments ──
venv/
env/
ENV/
.venv/
.env/
backend/venv/
backend/env/

# ── Environment Variables (CRITICAL - Never commit) ──
.env
.env.local
.env.development
.env.production
.env.staging
backend/.env
frontend/.env
*.env

# ── Google Cloud Credentials (CRITICAL - Never commit) ──
# Only ignore actual credential files, NOT package.json / package-lock.json
service-account*.json
gcloud-credentials.json
application_default_credentials.json
firebase-adminsdk*.json
*-firebase-adminsdk-*.json
*-credentials.json
credentials.json

# ── IDE and Editors ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS Generated ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Logs ──
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Testing ──
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/
.tox/
coverage/

# ── Node Modules ──
node_modules/
frontend/node_modules/

# ── Build Outputs ──
frontend/dist/
frontend/build/
build/
dist/

# ── Temporary Files ──
*.tmp
*.temp
*.bak
*.backup
*.orig

# ── Cache ──
.cache/
.eslintcache
.stylelintcache

# ── mypy ──
.mypy_cache/
.dmypy.json
dmypy.json